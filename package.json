{
	"name": "bas-connect",
	"version": "1.1.1",
	"description": "Automates BAS dev space startup and SSH tunnel creation.",
	"type": "module",
	"main": "dist/main.js",
	"bin": {
		"bas-connect": "bin/bas-connect"
	},
	"scripts": {
		"build": "tsc",
		"start": "node bin/bas-connect",
		"dev": "cross-env DEBUG=true node --experimental-transform-types --no-warnings=ExperimentalWarning src/main.ts",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix"
	},
	"author": "Jesse van der Velden",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/jessevelden/bas-connect.git"
	},
	"files": [
		"dist",
		"bin",
		"package.json",
		"README.md"
	],
	"dependencies": {
		"@microsoft/dev-tunnels-ssh": "3.12.29",
		"@microsoft/dev-tunnels-ssh-tcp": "3.12.29",
		"@sap/bas-sdk": "3.13.7",
		"dotenv": "17.4.2",
		"find-cache-directory": "6.0.0",
		"open": "11.0.0",
		"prompts": "2.4.2",
		"ssh-config": "5.1.0",
		"ws": "8.20.0"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"@types/open": "^6.2.1",
		"@types/prompts": "^2.4.9",
		"@types/ws": "^8.18.1",
		"cross-env": "^10.1.0",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.63.0",
		"oxlint-tsgolint": "^0.22.1",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=22"
	}
}
